{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "FreeX: Resume Work",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/resume-freex.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "FreeX: Create Checkpoint",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/checkpoint-freex.ps1"
            ],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "FreeX: Run Local",
            "type": "shell",
            "command": "npx",
            "args": [
                "vercel",
                "dev"
            ],
            "isBackground": true,
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "FreeX: Check Status",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "git status; Write-Host ''; git log -5 --oneline"
            ],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "FreeX: OK — Continue Interrupted Work",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& '${workspaceFolder}/scripts/resume-freex.ps1'; try { Set-Clipboard -Value 'ок'; Write-Host ''; Write-Host 'В буфер обмена скопировано: ок' -ForegroundColor Green } catch { Write-Host ''; Write-Host 'Не удалось скопировать в буфер обмена (не критично).' -ForegroundColor Yellow }"
            ],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
